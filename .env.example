# Board Room env contract — the full map of every variable the app reads.
# Copy the CLIENT section to .env.local for local dev (gitignored). The
# SERVER section is set in Netlify → Site configuration → Environment
# variables, never in a file that could reach the browser bundle.

# ─── CLIENT (Vite — inlined into the browser bundle at build time) ───────────
# Only ever put PUBLIC values behind the VITE_ prefix. Never a service-role
# key, never an Anthropic key (see lib/supabase.js for why).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Dev-only direct Anthropic calls (skips the claude function proxy). NEVER set
# this in Netlify's environment — builds run there and would inline it.
# VITE_ANTHROPIC_API_KEY=

# ─── SERVER (Netlify functions only — never VITE_-prefixed) ──────────────────
# Core
ANTHROPIC_API_KEY=            # claude proxy, audit, auto-fix, mini-worker, board-work, upstream engine
SUPABASE_URL=                 # session verification + service-role data access
SUPABASE_SERVICE_ROLE_KEY=    # bypasses RLS — functions only
OWNER_USER_ID=                # optional but recommended: pins the credentialed
                              # functions (claude/deploy/auto-fix/db-admin/
                              # fetch-page/audit/mini-worker/upstream) to your
                              # auth user id, so a stranger who signs up on the
                              # Supabase project still can't use them.

# Discord /board
DISCORD_PUBLIC_KEY=           # interaction signature verification + internal dispatch HMAC
BOARD_USER_ID=                # whose memory the Discord board reads/writes
# INTERNAL_FN_SECRET=         # optional: dedicated HMAC key for the discord-board →
                              # board-work-background hand-off (falls back to DISCORD_PUBLIC_KEY)

# Integrations (each optional — its card degrades gracefully)
SHOPIFY_SHOP=                 # *.myshopify.com subdomain only
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
GSC_CLIENT_EMAIL=             # Search Console service account
GSC_PRIVATE_KEY=              # PEM with literal \n sequences
GSC_SITE_URL=                 # optional override; defaults to sc-domain:zerotosecure.com
TMDB_API_KEY=                 # movie poster autofill (see tmdb.js header)
NETLIFY_API_TOKEN=            # deploy: trigger builds
GITHUB_TOKEN=                 # auto-fix: propose/commit static-file fixes

# Device bridges / exports
TRMNL_TOKEN=                  # e-ink device feed auth (see TRMNL.md)
TRMNL_USER_ID=                # whose data the TRMNL feed renders
BACKUP_SECRET=                # export-data auth
# (workout-import authenticates with a per-user token stored in the app's
#  workout settings, not an env var.)

# Misc
HOME_TZ=America/Chicago       # calendar-events display timezone (default shown)
