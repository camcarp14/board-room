# Config for scripts/miner-push.mjs — copy to .env.miner and fill in.
# .env.miner is gitignored; the service-role key must never be committed or
# shipped to the browser. It only ever lives on the machine doing the pushing.

# Board Room's Supabase project.
SUPABASE_URL=https://uyjkbvvgfiyarvptbooi.supabase.co

# Settings → API → service_role (the SECRET one, not anon/publishable):
# https://supabase.com/dashboard/project/uyjkbvvgfiyarvptbooi/settings/api-keys
SUPABASE_SERVICE_ROLE_KEY=

# Which account the samples belong to (cam.carp14@gmail.com). Not a secret —
# it's the RLS key that makes the rows visible to you and nobody else.
MINER_USER_ID=73751c09-6c07-4270-9f15-4f2984894e17

# Optional overrides.
MINER_URL=http://10.0.0.157/api/system/info
MINER_PUSH_INTERVAL_SEC=120
MINER_RETAIN_DAYS=14
